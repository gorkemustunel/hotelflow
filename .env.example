# Copy this file to .env and fill in your Supabase project's values
# (Project Settings → API in the Supabase dashboard).
#
# HotelFlow requires a real Supabase project to run — see README.md →
# "Backend kurulumu" for the full setup (run supabase/schema.sql, then
# scripts/seed-auth-users.mjs).
#
# VITE_SUPABASE_URL must be the project's base URL, WITHOUT any /rest/v1
# suffix — the Supabase client library builds the REST path itself.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed once, temporarily, to run `node scripts/seed-auth-users.mjs`.
# This is the "service_role" key (Project Settings → API) — it has full
# database access. Never put it in this file / .env — pass it inline on the
# command line instead, e.g.:
#   SUPABASE_SERVICE_ROLE_KEY=xxx node scripts/seed-auth-users.mjs
